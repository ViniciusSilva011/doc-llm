NODE_ENV=development
DEV_APP_PORT=3100
PROD_APP_PORT=3000
APP_URL=http://localhost:3100
PLAYWRIGHT_APP_URL=http://127.0.0.1:3100
TEST_REQUEST_BASE_URL=http://localhost
DATABASE_URL=postgres://postgres:postgres@localhost:5432/doc_llm
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/doc_llm_test
NEXTAUTH_SECRET=replace-me-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3100

LLM_PROVIDER=openrouter

OPENROUTER_API_KEY=replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-5-mini

OPENAI_API_KEY=replace-me
OPENAI_GENERATION_MODEL=gpt-5-mini
EMBEDDING_API_KEY=ollama
EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./data/uploads
STORAGE_MAX_UPLOAD_SIZE_BYTES=26214400

AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false
AWS_S3_PREFIX=

WORKER_POLL_INTERVAL_MS=5000
INGESTION_MAX_CHUNK_SIZE=1200
INGESTION_CHUNK_OVERLAP_PERCENT=20
INGESTION_QUERY_MATCH_LIMIT=5

DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=ChangeMe123!
