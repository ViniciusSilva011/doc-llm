{
  "name": "doc-llm",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/scripts/migrate.ts",
    "db:seed": "tsx src/db/scripts/seed.ts",
    "worker": "bash -o pipefail -c 'mkdir -p logs && tsx src/worker/index.ts 2>&1 | tee -a logs/worker.log'",
    "worker:dev": "tsx --watch src/worker/index.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "ask:ai": "tsx scripts/ask-ai.ts",
    "ask:document": "tsx scripts/ask-document.ts",
    "test:llm:connection": "tsx scripts/check-llm-connection.ts",
    "test:openrouter:connection": "tsx scripts/check-openrouter-connection.ts",
    "test:embedding:connection": "tsx scripts/check-embedding-connection.ts",
    "test:fetch-relevant-chunks": "tsx scripts/fetch-relevant-chunks.ts",
    "test:s3:connection": "tsx scripts/check-s3-connection.ts",
    "test:live": "npm run test:llm:connection && npm run test:embedding:connection && npm run test:s3:connection && npm run test:openrouter:connection",
    "test:watch": "vitest",
    "test:e2e": "PLAYWRIGHT_REUSE_SERVER=true playwright test",
    "ci": "npm run lint && npm run typecheck && npm run test",
    "reset": "docker compose exec db psql -U postgres -d doc_llm -c \"DROP SCHEMA IF EXISTS drizzle CASCADE; DROP SCHEMA IF EXISTS public CASCADE; CREATE SCHEMA public; CREATE SCHEMA drizzle;\" && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.883.0",
    "@cedrugs/pdf-parse": "^1.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.5",
    "lucide-react": "^1.8.0",
    "next": "^16.0.0",
    "next-auth": "^4.24.11",
    "openai": "^5.19.1",
    "pg": "^8.16.3",
    "postcss": "^8.5.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sbd": "^1.0.19",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
